      const extraHtml = extras.length ? `<div class="extra-examples">${extras.map(e => `<p>${esc(e.de || e)}<em>${esc(e.x || '')}</em></p>`).join('')}</div>` : '';
      return `<article class="vocab-card ${done ? 'done' : ''}" data-card="${esc(id)}">
        <div class="card-top"><span class="tag">${categories[item.c]}</span><span class="small">${done ? '已掌握' : '学习中'}</span></div>
        <button class="term-button" type="button" data-speak-word="${esc(item.t)}" aria-label="朗读单词：${esc(item.t)}">${esc(item.t)}</button>${item.p ? `<div class="plural">${esc(item.p)}</div>` : ''}
        <p class="translation">${esc(item.z)}</p>
        <p class="sentence">${esc(item.s)}<em>${esc(item.x)}</em></p>
        ${extraHtml}<p class="hint">提示：${esc(item.n || '点击德语词只读这个词；点击“读例句”读完整句。')}</p>
        <div class="actions"><button type="button" data-translate>翻译</button><button type="button" data-speak="${esc(item.s)}">读例句</button><a href="https://forvo.com/search/${encodeURIComponent(item.t)}/de/" target="_blank" rel="noopener">真人词音 ↗</a><a href="https://translate.google.com/?sl=de&tl=zh-CN&text=${encodeURIComponent(item.t)}&op=translate" target="_blank" rel="noopener">在线查词 ↗</a><button class="done-btn" type="button" data-done="${esc(id)}">${done ? '撤销' : '会了'}</button></div>
      </article>`;
    }
    function wireCards(root) {
      root.querySelectorAll('[data-speak]').forEach(btn=>btn.addEventListener('click',()=>speech(btn.dataset.speak)));
      root.querySelectorAll('[data-speak-word]').forEach(btn=>btn.addEventListener('click',()=>speech(btn.dataset.speakWord)));
      root.querySelectorAll('[data-translate]').forEach(btn=>btn.addEventListener('click',()=>btn.closest('.vocab-card').classList.toggle('show-translation')));
      root.querySelectorAll('[data-done]').forEach(btn=>btn.addEventListener('click',()=>{
        const id=btn.dataset.done; saved.has(id) ? saved.delete(id) : saved.add(id);
        localStorage.setItem('boutiqueGermanDone',JSON.stringify([...saved])); updateProgress(); renderToday(); renderAll();
      }));
    }
    function updateProgress() { const pct = Math.round(saved.size / vocab.length * 100); $('#progressNumber').textContent=pct+'%'; $('#ring').style.setProperty('--p',pct); }
    function renderToday() {
      const day=days[currentDay]; $('#dayTitle').textContent=day.title; $('#dayFocus').textContent=day.focus; $('#task').textContent=day.task;
      const set=vocab.filter(v=>day.cats.includes(v.c)).slice(0,8); const root=$('#todayCards'); root.innerHTML=set.map(card).join(''); wireCards(root);
      localStorage.setItem('boutiqueGermanDay',currentDay);
    }
    function renderFilters() {
      const root=$('#filters'); root.innerHTML=`<button class="chip ${activeCategory==='all'?'active':''}" data-filter="all">全部</button>`+Object.entries(categories).map(([id,name])=>`<button class="chip ${activeCategory===id?'active':''}" data-filter="${id}">${name}</button>`).join('');
      root.querySelectorAll('[data-filter]').forEach(btn=>btn.addEventListener('click',()=>{activeCategory=btn.dataset.filter;renderFilters();renderAll();}));
    }
    function renderAll() {
      const q=$('#search').value.trim().toLowerCase();
      const entries=vocab.filter(v=> (activeCategory==='all'||v.c===activeCategory) && [v.t,v.p,v.z,v.s,v.x,v.n].filter(Boolean).join(' ').toLowerCase().includes(q));
      $('#resultCount').textContent=`${entries.length} 张卡`;
      const root=$('#allCards'); root.innerHTML=entries.map(card).join('') || '<p class="hint">没有找到对应内容。试试搜索更短的词。</p>'; wireCards(root);
    }
    function renderGrammar() { $('#grammarCards').innerHTML=grammar.map(g=>`<article class="grammar-card"><div class="week">${g.w}</div><h3>${g.t}</h3><p>${g.r}</p><p class="example">${g.e}</p><p class="small">${g.x}</p><p class="hint">练习：${g.n}</p></article>`).join(''); }
    function renderRoadmap() { $('#roadmapCards').innerHTML=roadmap.map(r=>`<article class="road-card"><div class="week">${r.w}</div><h3>${r.t}</h3><p class="small">${r.d}</p></article>`).join(''); }
    function renderDw() {
      const root = $('#dwCards');
      root.innerHTML = dwUnits.map(unit => `<article class="dw-card ${dwDone.has(unit.n) ? 'done' : ''}"><div class="dw-level">第 ${unit.n} 单元 · ${unit.level}</div><h3>${unit.title}</h3><p><strong>${unit.dw}</strong></p><p class="small">语法：${unit.grammar}</p><p class="small">本站任务：${unit.task}</p><div class="actions"><a href="${dwCourseUrl}" target="_blank" rel="noopener">打开 DW ↗</a><button type="button" data-dw-vocab="${unit.category}">对应词库</button><button type="button" data-dw-tutor="${unit.scenario}">小老师练习</button><button class="done-btn" type="button" data-dw-done="${unit.n}">${dwDone.has(unit.n) ? '撤销完成' : '完成本单元'}</button></div></article>`).join('');
      root.querySelectorAll('[data-dw-vocab]').forEach(btn => btn.addEventListener('click',()=>{ activeCategory=btn.dataset.dwVocab; renderFilters(); renderAll(); $('#vocabulary').scrollIntoView({behavior:'smooth'}); }));
      root.querySelectorAll('[data-dw-tutor]').forEach(btn => btn.addEventListener('click',()=>{ startTutor(btn.dataset.dwTutor); $('#teacher').scrollIntoView({behavior:'smooth'}); }));
      root.querySelectorAll('[data-dw-done]').forEach(btn => btn.addEventListener('click',()=>{ const id=Number(btn.dataset.dwDone); dwDone.has(id) ? dwDone.delete(id) : dwDone.add(id); localStorage.setItem('boutiqueGermanDwDone', JSON.stringify([...dwDone])); renderDw(); }));
    }
    $('#prevDay').addEventListener('click',()=>{currentDay=(currentDay+days.length-1)%days.length;renderToday();});
    $('#nextDay').addEventListener('click',()=>{currentDay=(currentDay+1)%days.length;renderToday();});
    $('#search').addEventListener('input',renderAll);
    $('#onlineLookup').addEventListener('click',()=>{
      const word = $('#search').value.trim();
      if (!word) { toast('先在搜索框输入要查的德语词。'); return; }
      window.open(`https://translate.google.com/?sl=auto&tl=zh-CN&text=${encodeURIComponent(word)}&op=translate`, '_blank', 'noopener');
    });
    $('#chatLog').addEventListener('click', event => { const button = event.target.closest('[data-tutor-speak]'); if (button) speech(button.dataset.tutorSpeak); });
    $('#tutorForm').addEventListener('submit', event => { event.preventDefault(); const input = $('#tutorInput'); const value = input.value.trim(); if (!value) return; addTutorMessage('user', value); input.value = ''; sendTutorReply(value); });
    document.querySelectorAll('[data-scenario]').forEach(btn => btn.addEventListener('click',()=>startTutor(btn.dataset.scenario)));
    renderFilters(); renderAll(); renderToday(); renderGrammar(); renderRoadmap(); renderDw(); renderNumberLab(); startTutor('intro'); updateProgress();
  </script>
</body>
